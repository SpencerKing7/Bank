rules_version = '2';

// Paste into: Firebase console -> Firestore Database -> Rules -> Publish.
//
// Model: the host's client is the only writer of the game doc. Player docs have
// two writers with disjoint field sets — a player writes their own points and
// bankedRound, the host writes anyone's `order` (seat) and may delete anyone.
// Anonymous Auth supplies request.auth.uid. Known, accepted limitation for a
// family game: a player could inflate their own points from a dev console.
service cloud.firestore {
  match /databases/{db}/documents {
    match /games/{code} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.hostId == request.auth.uid
                    && code.matches('^[A-HJ-NP-Z]{4}$');
      allow update: if request.auth != null
                    && resource.data.hostId == request.auth.uid
                    && request.resource.data.hostId == resource.data.hostId;
      // Host may end the game; deleting the doc resets every player's screen.
      allow delete: if request.auth != null
                    && resource.data.hostId == request.auth.uid;

      function isHost() {
        return request.auth != null
               && get(/databases/$(db)/documents/games/$(code)).data.hostId
                    == request.auth.uid;
      }

      match /players/{playerId} {
        allow read: if request.auth != null;
        allow create: if request.auth.uid == playerId
                      && request.resource.data.points == 0;
        // Two writers, each confined to its own fields: a player moves their
        // own score, and the host moves anyone's seat (lobby drag-to-reorder,
        // and the renumber that closes the gap after a removal). Neither can
        // reach the other's keys — the host cannot award points, and a player
        // cannot reseat the table.
        allow update: if (request.auth.uid == playerId
                          && request.resource.data.diff(resource.data)
                               .affectedKeys().hasOnly(['points', 'bankedRound']))
                      || (isHost()
                          && request.resource.data.diff(resource.data)
                               .affectedKeys().hasOnly(['order']));
        // Host cleanup when ending a game, and removing a single player from
        // the lobby. Inside the endGame delete batch, get() reads pre-batch
        // state, so this passes even though the game doc is deleted in the
        // same batch.
        allow delete: if isHost();
      }
    }
  }
}
