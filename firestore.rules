rules_version = '2';

// Paste into: Firebase console -> Firestore Database -> Rules -> Publish.
//
// Model: the host's client is the only writer of the game doc; every player
// (host included) may only write their own player doc. Anonymous Auth supplies
// request.auth.uid. Known, accepted limitation for a family game: a player
// could inflate their own points from a dev console.
service cloud.firestore {
  match /databases/{db}/documents {
    match /games/{code} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.hostId == request.auth.uid
                    && code.matches('^[A-HJ-NP-Z]{4}$');
      allow update: if request.auth != null
                    && resource.data.hostId == request.auth.uid
                    && request.resource.data.hostId == resource.data.hostId;
      allow delete: if false;

      match /players/{playerId} {
        allow read: if request.auth != null;
        allow create: if request.auth.uid == playerId
                      && request.resource.data.points == 0;
        allow update: if request.auth.uid == playerId
                      && request.resource.data.diff(resource.data)
                           .affectedKeys().hasOnly(['points', 'bankedRound']);
        allow delete: if false;
      }
    }
  }
}
