# Copy to .env.local and fill in from:
# Firebase console -> Project settings -> Your apps -> (your web app) -> SDK setup and configuration
#
# These values are public by design (Firestore security rules do the
# protecting); .env.local just keeps them out of the repo.
REACT_APP_FIREBASE_API_KEY=
REACT_APP_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=your-project-id
REACT_APP_FIREBASE_APP_ID=
